# EPIC GWAS Pipeline Environment Variables
# Copy this file to .env and fill in the paths.
# All paths should be absolute or relative to the project root.

# --- Core Paths ---
# The root directory of the GWAS project
GWAS_PROJECT_ROOT="work/GWAS"

# The directory where analysis results should be stored
GWAS_ANALYSIS_DIR="work/GWAS/analysis"

# --- Source Data Paths ---
# Path to the genotype data directory
GWAS_GENETICS_DIR="work/GWAS/data/genetics"

# Path to the phenotype file
GWAS_PHENO_FILE="work/GWAS/data/phenotype/phenofile.txt"

# Path to the samplesheet
GWAS_SAMPLESHEET="work/GWAS/pipeline/samplesheet.csv"

# --- Tools and External Resources ---
# Path to the bundled METAL binary
GWAS_METAL_BIN="work/GWAS/pipeline/tools/metal/metal"

# Path to external RDS files used in R scripts
GWAS_EXTERNAL_SOMA_RDS="Data_Phase2/NormalizedSoma_PlateCorrAccountforDisease_InvRank.rds"
GWAS_DEPOT_GENETICS_DIR="Depot_Gwas/sources/final_20260512"
