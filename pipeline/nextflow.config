// =============================================================================
// Usage:
//   nextflow run pipeline.nf -profile slurm
//   nextflow run pipeline.nf -profile test
// =============================================================================

conda.enabled = true

process {
  cache         = true
  cpus          = 1
  memory        = '8.GB'
  time          = '1.h'
  errorStrategy = 'terminate'
  maxRetries    = 0

  withName: SAMPLE_QC {
    cpus   = 2
    memory = '4.GB'
    time   = '4.h'
  }
  withName: VARIANT_QC {
    cpus   = 2
    memory = '4.GB'
    time   = '4.h'
  }
  withName: STAGE_SAMPLE_QC {
    cpus   = 2
  }
  withName: STAGE_VARIANT_QC {
    cpus   = 2
  }
  withName: LD_PRUNING {
    cpus   = 2
    memory = '4.GB'
    time   = '4.h'
  }
  withName: PCA {
    cpus   = 2
    memory = '1.GB'
    time   = '4.h'
  }
  withName: REGENIE_STEP0 {
    cpus   = 2
    time   = '4.h'
  }
  withName: REGENIE_STEP1 {
    memory  = '2.GB'
    time   = '4.h'
    scratch = true
  }
  withName: REGENIE_STEP2 {
    memory  = '1.GB'
    time    = '2.h'
    scratch = true
  }
  withName: GWAS_QC {
    cpus = 2
    memory = '4.GB'
    time = '2.h'
  }
  withName: META_GROUP {
    cpus  = 1
    memory = '6.GB'
    time = '2.h'
  }
  withName: META_STUDY {
    cpus   = 1
    memory = '6.GB'
    time   = '2.h'
  }
  withName: COHORT_SUMMARY {
    memory = '1.GB'
  }
}

profiles {

  // ---------------------------------------------------------------------------
  // slurm — base SLURM profile: partitions, memory, error handling.
  // Queue size caps the number of active submitted Slurm tasks for this run.
  // ---------------------------------------------------------------------------
  slurm {
    process {
      executor      = 'slurm'
      queue         = 'low_p'
      errorStrategy = { task.exitStatus in [130, 137, 139, 140, 143] ? 'retry' : 'finish' }
      maxRetries    = 2

      withName: REGENIE_STEP0 {
        cpus          = 2
        time          = '4.h'
        errorStrategy = 'terminate'
        maxRetries    = 0
      }
      withName: REGENIE_STEP1 {
        memory        = '2.GB'
        time          = '4.h'
        scratch       = true
        errorStrategy = 'terminate'
        maxRetries    = 0
      }
      withName: GWAS_QC {
        cache    = false
        cpus     = 2
        memory = { 4.GB * task.attempt }
        time     = '2.h'
      }
      withName: META_GROUP {
        cache    = false
        cpus     = 1
        memory = { 6.GB * task.attempt }
        time     = '2.h'
      }
      withName: META_STUDY {
        cache    = false
        cpus     = 1
        memory = { 6.GB * task.attempt }
        time     = '2.h'
      }
    }
    executor {
      name            = 'slurm'
      queueSize       = 1000
      submitRateLimit = '1000/1min'
      pollInterval    = '30 sec'    // How often Nextflow polls SLURM to refresh job states.
      exitReadTimeout = '10 min'    // How long Nextflow waits to read final task metadata after a job exits.
      jobName         = { "${task.process.tokenize(':').last()}_${task.index}" }
    }
  }

  // ---------------------------------------------------------------------------
  // test — local execution for pipeline development
  // ---------------------------------------------------------------------------
  test {
    params {
      chunk_size  = 3
      chromosomes = [21]
    }
    process {
      executor = 'local'
      cpus     = 2
      memory   = '8.GB'
    }
  }

}

report {
  enabled = true
  file    = "${params.outdir}/pipeline_info/execution_report.html"
  overwrite = true
}

timeline {
  enabled = true
  file    = "${params.outdir}/pipeline_info/execution_timeline.html"
  overwrite = true
}

trace {
  enabled = true
  file    = "${params.outdir}/pipeline_info/execution_trace.txt"
  overwrite = true
}
